{
  "schema": "comic_catalog_discovery_sources_v1",
  "updatedAt": "2026-07-01T00:00:00Z",
  "description": "独立公开目录发现源，仅供 GitHub Actions 生成 catalog.json 使用。APP 搜索与阅读继续使用 generated/index.json，不读取本文件。",
  "compliance": {
    "publicOnly": true,
    "metadataOnly": true,
    "noImages": true,
    "noChapterText": true,
    "noAccountData": true
  },
  "defaults": {
    "maxPages": 5,
    "maxItemsPerSource": 500,
    "requestTimeoutSeconds": 15,
    "itemRegex": "<a[^>]+href=[\"']([^\"']*(?:comic|manga|manhua|book|series|title|read)[^\"']*)[\"'][^>]*>([\\s\\S]{0,320}?)<\\/a>",
    "urlGroups": [1],
    "titleGroups": [2],
    "nextPageRegex": "<a[^>]+href=[\"']([^\"']+)[\"'][^>]*>(?:\\s*下一页\\s*|\\s*下页\\s*|\\s*Next\\s*|\\s*&gt;\\s*)<\\/a>",
    "nextPageUrlGroups": [1]
  },
